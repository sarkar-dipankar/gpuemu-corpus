{
  "name": "softmax_triton_buggy",
  "source": "llm:demo-triton",
  "benchmark_verdict": "pass",
  "input_names": ["input"],
  "reference": "softmax/ref_fp64.py",
  "kernel": "softmax_triton_buggy/kernel.py",
  "dtypes": ["float32", "float16"],
  "tolerances": {"float32": 1e-5, "float16": 2e-2},
  "requires_gpu": true,
  "notes": "Real Triton kernel with the tail-masking bug (other=0.0 instead of -inf). Correct only when n_cols is a power of two; gpuemu's fuzz schema includes 3, 1025, ... to expose it.",
  "op_schema": {
    "name": "softmax",
    "dims": [
      {"name": "B", "candidates": [1, 2, 8]},
      {"name": "S", "candidates": [1, 7, 128]},
      {"name": "H", "candidates": [3, 256, 1025]}
    ],
    "inputs": [{"name": "input", "dims": ["B", "S", "H"]}],
    "output": {"name": "out", "dims": ["B", "S", "H"]}
  }
}
